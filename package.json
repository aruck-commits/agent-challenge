{
  "name": "orion-defi-risk-officer",
  "version": "1.0.0",
  "description": "Personal Solana DeFi Risk Officer — monitor, score, and alert on your Solana DeFi positions",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev ./src/ui -p 3000",
    "dev:legacy": "concurrently -n agent,ui -c cyan,magenta \"npm run dev:agent\" \"npm run dev:ui\"",
    "dev:agent": "tsx watch src/agent/index.ts",
    "dev:ui": "NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api next dev ./src/ui -p 5173",
    "build": "next build ./src/ui",
    "build:agent": "tsc --project tsconfig.agent.json",
    "build:ui": "next build ./src/ui",
    "start": "next start ./src/ui -p 3000",
    "start:standalone": "node src/ui/.next/standalone/src/ui/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elizaos/client-telegram": "^0.25.6-alpha.1",
    "@elizaos/core": "^2.0.0-alpha.77",
    "@elizaos/plugin-solana": "^1.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@solana/wallet-adapter-backpack": "^0.1.14",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-phantom": "^0.9.29",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-solflare": "^0.6.33",
    "@solana/web3.js": "^1.95.4",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "dotenv": "^16.4.7",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "^15.5.5",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "sharp": "^0.34.5",
    "tw-animate-css": "^1.4.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
